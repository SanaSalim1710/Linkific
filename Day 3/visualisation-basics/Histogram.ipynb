   "source": [
    "import matplotlib.pyplot as plt\n",
    "import random\n",
    "\n",
    "step_count = []\n",
    "for i in range(100):\n",
    "    step_count.append(random.randint(1,15))\n",
    "\n",
    "plt.hist(step_count)\n",
    "plt.title(\"Daily Step Count Distribution\")\n",
    "plt.xlabel(\"Steps (K)\")\n",
    "plt.ylabel(\"People\")\n",
    "\n",
    "plt.show()"
   ]
  }
